@page "/admin/login"
@using VacationTracker.Services
@inject AuthService Auth
@inject NavigationManager Nav

<div class="login-container d-flex align-items-center justify-content-center min-vh-100">
    <div class="login-card animate-fade-in">
        <div class="login-header text-center">
            <div class="login-icon-box mb-3 mx-auto shadow-sm">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <h2 class="fw-black mb-1" style="color: #0f172a;">Espace Admin</h2>
            <p class="text-muted small fw-medium">PROVINCE DE BERKANE</p>
        </div>
        
        <div class="login-body mt-4">
            <div class="mb-3">
                <label class="form-label small fw-bold text-muted text-uppercase mb-2" style="letter-spacing: 0.05em;">Identifiant Personnel</label>
                <div class="input-group-custom">
                    <i class="bi bi-person text-success"></i>
                    <input type="text" class="form-control-premium" @bind="username" @onkeydown="CheckEnter" placeholder="Nom d'utilisateur" />
                </div>
            </div>
            
            <div class="mb-4">
                <label class="form-label small fw-bold text-muted text-uppercase mb-2" style="letter-spacing: 0.05em;">Mot de Passe</label>
                <div class="input-group-custom">
                    <i class="bi bi-key text-success"></i>
                    <input type="password" class="form-control-premium" @bind="password" @onkeydown="CheckEnter" placeholder="••••••••" />
                </div>
            </div>

            <button class="btn btn-premium-login w-100 py-3 shadow-sm" @onclick="AttemptLogin">
                Connecter la Session
            </button>
            
            @if (showError)
            {
                <div class="alert alert-danger-custom mt-4 animate-fade-in d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <span class="small fw-bold">Accès Refusé : Identifiants invalides.</span>
                </div>
            }
        </div>

        <div class="login-footer mt-5 text-center px-4">
            <p class="text-muted small opacity-75 mb-0">
                Système Interne de Gestion des Congés & Missions de la Province.
            </p>
        </div>
    </div>
</div>

@code {
    private string username = "";
    private string password = "";
    private bool showError = false;

    private void AttemptLogin()
    {
        if (Auth.Login(username, password))
        {
            showError = false;
            Nav.NavigateTo("/admin/manage", forceLoad: false);
        }
        else
        {
            showError = true;
        }
    }

    private void CheckEnter(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AttemptLogin();
    }
}

<style>
    .login-container {
        background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
        position: relative;
        overflow: hidden;
    }
    .login-container::before {
        content: "";
        position: absolute;
        width: 600px; height: 600px;
        background: radial-gradient(circle, rgba(0, 62, 51, 0.03) 0%, transparent 70%);
        top: -100px; right: -100px;
    }
    .login-card {
        width: 100%;
        max-width: 420px;
        background: white;
        padding: 2.5rem;
        border-radius: 2rem;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.8);
        z-index: 1;
    }
    .login-icon-box {
        width: 64px; height: 64px;
        background: var(--primary-green);
        color: white;
        border-radius: 1.25rem;
        display: flex;
        align-items: center; justify-content: center;
        font-size: 1.75rem;
    }
    .input-group-custom {
        position: relative;
        display: flex; align-items: center;
    }
    .input-group-custom i {
        position: absolute; left: 1.25rem;
        font-size: 1.1rem;
    }
    .form-control-premium {
        width: 100%;
        padding: 0.85rem 1.25rem 0.85rem 3.25rem;
        border: 2px solid #f1f5f9;
        border-radius: 1rem;
        background: #f8fafc;
        transition: all 0.3s;
        font-weight: 500;
        outline: none;
    }
    .form-control-premium:focus {
        border-color: var(--primary-green);
        background: white;
        box-shadow: 0 0 0 4px rgba(0, 62, 51, 0.05);
    }
    .btn-premium-login {
        background: var(--primary-green);
        color: white;
        border: none;
        border-radius: 1rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        transition: all 0.3s;
    }
    .btn-premium-login:hover {
        background: #002d25;
        transform: translateY(-2px);
        box-shadow: 0 10px 15px -3px rgba(0, 62, 51, 0.3);
    }
    .alert-danger-custom {
        background: #fff1f2;
        border: 1px solid #ffe4e6;
        color: #e11d48;
        padding: 0.75rem 1.25rem;
        border-radius: 1rem;
    }
</style>
