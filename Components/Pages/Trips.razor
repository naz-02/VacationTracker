@page "/trips"
@using VacationTracker.Models
@using VacationTracker.Services
@inject DatabaseService DbService
@inject NavigationManager NavManager

<div class="row animate-fade-in justify-content-center mt-4">
    <div class="col-lg-8">
        <div class="admin-card border-top border-4 border-success">
            <div class="form-container">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-green-soft p-2 rounded-3 text-success me-3">
                        <i class="bi bi-plus-lg fs-4"></i>
                    </div>
                    <div>
                        <h4 class="mb-0 fw-bold">Nouvelle Demande</h4>
                        <small class="text-muted">Enregistrez un nouveau dossier de congé</small>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase">Employé / الموظف</label>
                    <select class="form-select form-select-lg rounded-3 shadow-sm border-0 bg-light" @bind="selectedEmployeeId">
                        <option value="0">-- Sélectionner l'employé --</option>
                        @if (employees != null)
                        {
                            @foreach (var emp in employees)
                            {
                                <option value="@emp.Id">@emp.FullName (@emp.Role)</option>
                            }
                        }
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold small text-uppercase">Nature du Congé / نوع الرخصة</label>
                    <select class="form-select form-select-lg rounded-3 shadow-sm border-0 bg-light" @bind="newTrip.LeaveType">
                        <option value="Annuel">Congé Annuel</option>
                        <option value="Exceptionnelle">Autorisation d'absence Exceptionnelle</option>
                    </select>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-uppercase">Date de Début</label>
                        <input type="date" class="form-control form-control-lg rounded-3 shadow-sm border-0 bg-light" @bind="newTrip.StartDate" @bind:after="UpdateOverlappingHolidays" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small text-uppercase">Date de Fin</label>
                        <input type="date" class="form-control form-control-lg rounded-3 shadow-sm border-0 bg-light" @bind="newTrip.EndDate" @bind:after="UpdateOverlappingHolidays" />
                    </div>
                </div>

                @if (overlappingHolidays != null && overlappingHolidays.Any())
                {
                    <div class="alert alert-danger rounded-3 shadow-sm mb-4">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-calendar-event me-2 fs-5"></i>
                            <strong class="text-uppercase small">Jours Fériés Détectés (Non déduits du solde)</strong>
                        </div>
                        <ul class="mb-0 ps-3 small fw-bold">
                            @foreach (var h in overlappingHolidays)
                            {
                                <li>@h.Name (@h.Date.ToString("dd MMMM yyyy"))</li>
                            }
                        </ul>
                    </div>
                }

                <button type="button" @onclick="HandleSubmit" class="btn btn-premium w-100 py-3 shadow">
                    SOUMETTRE LA DEMANDE
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Employee>? employees;
    private List<Holiday>? allHolidays;
    private List<Holiday> overlappingHolidays = new();
    private Trip newTrip = new Trip { StartDate = DateTime.Today, EndDate = DateTime.Today.AddDays(1), LeaveType = "Annuel" };
    private int selectedEmployeeId = 0;

    protected override async Task OnInitializedAsync()
    {
        employees = await DbService.GetEmployeesAsync();
        allHolidays = await DbService.GetHolidaysAsync();
        UpdateOverlappingHolidays();
    }

    private void UpdateOverlappingHolidays()
    {
        if (allHolidays == null) return;
        
        overlappingHolidays = allHolidays
            .Where(h => h.Date >= newTrip.StartDate.Date && h.Date <= newTrip.EndDate.Date)
            .ToList();
    }

    private async Task HandleSubmit()
    {
        if (selectedEmployeeId == 0) return;

        newTrip.EmployeeId = selectedEmployeeId;
        newTrip.Status = "En attente";

        int res = await DbService.AddTripAsync(newTrip);
        if (res > 0)
        {
            newTrip = new Trip { StartDate = DateTime.Today, EndDate = DateTime.Today.AddDays(1), LeaveType = "Annuel" };
            selectedEmployeeId = 0;
            NavManager.NavigateTo("/admin/manage"); // Redirection to proof submission
        }
    }
}
