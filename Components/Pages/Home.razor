@page "/"
@using VacationTracker.Services
@inject DatabaseService DbService
@inject NavigationManager Nav

<div class="animate-fade-in">
    <!-- HERO SECTION -->
    <div class="admin-card p-0 overflow-hidden mb-5 border-0" style="background: linear-gradient(135deg, #006233 0%, #004d28 100%); min-height: 300px;">
        <div class="row h-100 g-0">
            <div class="col-md-7 p-5 d-flex flex-column justify-content-center text-white">
                <span class="badge mb-3 px-3 py-2 rounded-pill" style="background: rgba(255,255,255,0.1); width: fit-content; border: 1px solid rgba(255,255,255,0.2);">VERSION 2.0 PREMIUM</span>
                <h1 class="display-5 fw-black mb-3 text-white">Gestion Intellectuelle des Congés</h1>
                <p class="lead opacity-75 mb-4">Optimisez le suivi des absences et automatisez l'édition des décisions administratives pour le Conseil Provincial de Berkane.</p>
                <div class="d-flex gap-3">
                    <button class="btn btn-light btn-lg rounded-pill px-4 fw-bold text-success shadow" @onclick='() => Nav.NavigateTo("/trips")'>
                        <i class="bi bi-plus-circle-fill me-2"></i> Nouvelle Demande
                    </button>
                    <button class="btn btn-outline-light btn-lg rounded-pill px-4 fw-bold" @onclick='() => Nav.NavigateTo("/admin/manage")'>
                        Espace Admin
                    </button>
                </div>
            </div>
            <div class="col-md-5 d-none d-md-block position-relative" style="background: url('images/logo_berkane.png') center center no-repeat; background-size: 60%; opacity: 0.15; filter: grayscale(1) invert(1);">
            </div>
        </div>
    </div>

    <!-- STATS GRID -->
    <div class="row g-4">
        <div class="col-md-4">
            <div class="admin-card h-100 border-start border-4 border-success">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 1px;">Effectif Total</p>
                        <h2 class="fw-black mb-0">@employeeCount</h2>
                    </div>
                    <div class="bg-green-soft p-3 rounded-4 text-success">
                        <i class="bi bi-people-fill fs-3"></i>
                    </div>
                </div>
                <div class="mt-3 small text-success fw-bold">
                    <i class="bi bi-person-check-fill me-1"></i> Personnel Permanent
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="admin-card h-100 border-start border-4 border-warning">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 1px;">En Attente</p>
                        <h2 class="fw-black mb-0">@pendingCount</h2>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-3 rounded-4 text-warning">
                        <i class="bi bi-hourglass-split fs-3"></i>
                    </div>
                </div>
                <div class="mt-3 small text-muted font-italic">
                    Dossiers nécessitant une validation
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="admin-card h-100 border-start border-4 border-info">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small fw-bold text-uppercase mb-1" style="letter-spacing: 1px;">Jours Fériés</p>
                        <h2 class="fw-black mb-0">@holidayCount</h2>
                    </div>
                    <div class="bg-info bg-opacity-10 p-3 rounded-4 text-info">
                        <i class="bi bi-calendar-event fs-3"></i>
                    </div>
                </div>
                <div class="mt-3 small text-info fw-bold">
                    Calendrier Officiel 2026
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .fw-black { font-weight: 900; }
</style>

@code {
    private int employeeCount = 0;
    private int pendingCount = 0;
    private int holidayCount = 0;

    protected override async Task OnInitializedAsync()
    {
        var employees = await DbService.GetEmployeesAsync();
        employeeCount = employees?.Count ?? 0;

        var trips = await DbService.GetTripsAsync();
        pendingCount = trips?.Count(t => t.Status == "En attente" || t.Status == "Pending") ?? 0;

        var holidays = await DbService.GetHolidaysAsync();
        holidayCount = holidays?.Count ?? 0;
    }
}
